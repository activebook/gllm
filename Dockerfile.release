# Stage 1: Final Image wrapping pre-built Goreleaser binary
FROM alpine:3.21

# Install runtime dependencies (CA certificates for API calls, Node.js for MCP servers)
RUN apk add --no-cache \
    ca-certificates \
    tzdata \
    nodejs \
    npm \
    python3 \
    py3-pip \
    ttyd

# Create a non-root user for security
RUN adduser -D -g '' gllmuser

WORKDIR /home/gllmuser

# Goreleaser automatically copies the compiled binary to the working context
COPY gllm /usr/local/bin/gllm

# Set the user
USER gllmuser

# Define the entrypoint
ENTRYPOINT ["gllm"]
